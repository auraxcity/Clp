# Firebase Admin (required for Pesapal API routes + optional one-command rules deploy)
#
# EASIEST: download "Generate new private key" JSON from Firebase Console → Project settings →
# Service accounts, save as firebase-adminsdk.local.json in the project root (gitignored).
#
# OR paste the entire JSON as one line:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"clpx-e5c07",...}
#
# OR split fields (private key often uses \n for newlines in .env):
FIREBASE_ADMIN_PROJECT_ID=clpx-e5c07
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-fbsvc@clpx-e5c07.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
#
# Publish Firestore rules (uses same credentials as above): npm run deploy:firestore-rules
# Or after `npm run firebase:login`: npm run firebase:deploy-rules

# Minimum investor investment in UGX (default in app is 1 for testing). Production example: 100000
# NEXT_PUBLIC_MIN_INVESTMENT_AMOUNT=100000
